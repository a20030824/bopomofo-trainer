{
  "name": "bopomofo-trainer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pretypecheck": "npm run spike:catalog",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "catalog:validate": "tsx scripts/validate-catalog.ts",
    "catalog:build": "tsx scripts/compile-catalog.ts",
    "spike:catalog": "tsx scripts/compile-spike-catalog.ts",
    "predev": "npm run spike:catalog",
    "dev": "vite",
    "prebuild": "npm run spike:catalog",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run typecheck && npm test && npm run catalog:validate && npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
